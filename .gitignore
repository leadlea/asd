# まず全部無視
*

# ---- ここから必要なものだけ再許可 ----

# この .gitignore 自身
!.gitignore

# ルートの README と requirements
!README.md
!requirements.txt

# config: pragmatics 用インデックス
!config/
!config/pragmatics_index_catalog.csv

# scripts: Nanami pragmatics 用のスクリプト
!scripts/
!scripts/*.py
!scripts/paper_figs/
!scripts/paper_figs/*.py
!scripts/analysis/
!scripts/analysis/*.py

# scripts: CEJC前処理
!scripts/cejc/
!scripts/cejc/*.py

# audio_mvp: 音声解析スクリプト
!audio_mvp/
!audio_mvp/*.py

# docs: index.html だけ
!docs/
!docs/*.html
!docs/*.md
!docs/**/*.md
# Nanami のアウトプット一式
!out/
!out/audio/
!out/audio/Nanami/
!out/audio/Nanami/**

# macOS のゴミ
.DS_Store


# docs: report（PDF）を許可
!docs/report/
!docs/report/*.pdf
# Phase3 pipeline
!scripts/phase3/
!scripts/phase3/**

!docs/report/*.html
!docs/report/*.md


# ---- generated artifacts (local) ----
docs/*
!docs/homework/
!docs/homework/**
scripts/**/__pycache__/
**/__pycache__/
*.pyc
artifacts/

# tmp/_inspect: 特徴量棚卸しドキュメント（許可）
!tmp/
!tmp/_inspect/
!tmp/_inspect/**

# ---- local inspection outputs ----
tmp/_inspect/

# docs: minutes（議事録）を許可
!docs/minutes/
!docs/minutes/**

# reports: 論文用図表（PNG + LaTeX tables）
!reports/
!reports/paper_figs_v2/
!reports/paper_figs_v2/*.png
!reports/paper_figs_v2/*.tex
!reports/paper_figs_v2/*.html

# 論文本体（LaTeX + PDF）
!paper1_ja.tex
!paper1_ja.pdf

# .kiro: specs / steering
!.kiro/
!.kiro/**
